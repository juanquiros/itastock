{% extends 'base.html.twig' %}

{% block title %}Productos · ItaStock{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .product-header { gap: 1rem; }
        .product-toolbar { gap: 0.5rem; }
        .product-actions { gap: 0.35rem; }
        @media (max-width: 991.98px) {
            .product-header { flex-direction: column; align-items: flex-start; }
            .product-toolbar { width: 100%; }
            .product-toolbar .btn { width: 100%; }
            .product-actions { flex-direction: column; align-items: stretch; }
            .product-actions .btn { width: 100%; }
        }
    </style>
{% endblock %}

{% block body %}
    {% set nextDir = filters.dir == 'asc' ? 'desc' : 'asc' %}
    {% set baseQuery = { q: filters.q, limit: filters.limit } %}

    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap product-header">
        <div>
            <p class="text-uppercase text-muted mb-1 small fw-semibold">Inventario</p>
            <h1 class="h4 mb-0">Productos</h1>
            <p class="text-secondary mb-0">Seguimiento de stock y precios. Controlá lo que se vende todos los días.</p>
        </div>
        <div class="d-flex flex-wrap justify-content-end product-toolbar">
            <a class="btn btn-outline-secondary" href="{{ path('app_product_export') }}">Exportar CSV</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_product_import') }}">Importar CSV</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_stock_import') }}">Ajustes por CSV</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_product_labels') }}">Etiquetas</a>
            <a class="btn btn-primary" href="{{ path('app_product_new') }}">Nuevo producto</a>
        </div>
    </div>

    <div class="card shadow-sm mb-3" data-controller="barcode-scanner" data-barcode-scanner-script-url-value="{{ asset('vendor/html5-qrcode.min.js') }}">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-lg-7 col-md-12">
                    <label class="form-label">Búsqueda</label>
                    <div class="input-group" data-barcode-scanner-input-group>
                        <input type="search" name="q" id="product-search-filter" class="form-control" value="{{ filters.q }}" placeholder="Nombre, SKU o código de barra" data-barcode-scanner-target="input" data-barcode-scanner-input="true">
                        <button class="btn btn-outline-secondary d-inline-flex d-lg-none" type="button" data-action="barcode-scanner#open" data-barcode-scanner-input-id-param="product-search-filter">Escanear</button>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label">Mostrar</label>
                    <select name="limit" class="form-select" onchange="this.form.submit()">
                        {% for option in [25, 50, 100] %}
                            <option value="{{ option }}" {{ filters.limit == option ? 'selected' : '' }}>{{ option }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-1 col-md-6 d-grid">
                    <button class="btn btn-outline-secondary" type="submit">Filtrar</button>
                </div>
                <div class="col-lg-2 col-md-6 d-grid">
                    <a class="btn btn-link text-decoration-none" href="{{ path('app_product_index') }}">Limpiar filtros</a>
                </div>
            </form>
            {% include 'shared/_barcode_scanner_modal.html.twig' %}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <a class="text-decoration-none text-dark" href="{{ path('app_product_index', baseQuery|merge({ sort: 'name', dir: filters.sort == 'name' ? nextDir : 'asc', page: 1 })) }}">Producto</a>
                            </th>
                            <th>
                                <a class="text-decoration-none text-dark" href="{{ path('app_product_index', baseQuery|merge({ sort: 'sku', dir: filters.sort == 'sku' ? nextDir : 'asc', page: 1 })) }}">SKU</a>
                            </th>
                            <th>Categoría</th>
                            <th class="text-end">Precio base</th>
                            <th class="text-end">
                                <a class="text-decoration-none text-dark" href="{{ path('app_product_index', baseQuery|merge({ sort: 'stock', dir: filters.sort == 'stock' ? nextDir : 'asc', page: 1 })) }}">Stock</a>
                            </th>
                            <th class="text-end">Stock mínimo</th>
                            <th>
                                <a class="text-decoration-none text-dark" href="{{ path('app_product_index', baseQuery|merge({ sort: 'updatedAt', dir: filters.sort == 'updatedAt' ? nextDir : 'asc', page: 1 })) }}">Estado</a>
                            </th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in products %}
                            {% set lowStock = (product.stock + 0) <= (product.stockMin + 0) %}
                            <tr class="{{ lowStock ? 'table-warning' : '' }}">
                                <td class="fw-semibold">{{ product.name }}</td>
                                <td class="text-muted">{{ product.sku }}</td>
                                <td>{{ product.category ? product.category.name : 'Sin categoría' }}</td>
                                <td class="text-end">${{ product.basePrice|number_format(2, '.', ',') }}</td>
                                <td class="text-end fw-semibold">{{ product.stock|number_format(3, '.', ',') }} <span class="text-muted">{{ product.uomBase }}</span></td>
                                <td class="text-end text-muted">{{ product.stockMin|number_format(3, '.', ',') }}</td>
                                <td>{% if product.isActive %}<span class="badge bg-success">Activo</span>{% else %}<span class="badge bg-secondary">Inactivo</span>{% endif %}</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end flex-wrap product-actions">
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_product_edit', { id: product.id }) }}">Editar</a>
                                        <form method="post" action="{{ path('app_product_delete', { id: product.id }) }}" onsubmit="return confirm('¿Eliminar este producto?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td class="text-center text-muted" colspan="8">Aún no hay productos cargados.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <div class="text-muted small">Mostrando página {{ pagination.page }} de {{ pagination.pages }} · {{ pagination.total }} productos</div>
            {% if pagination.pages > 1 %}
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        {% set prevPage = pagination.page - 1 %}
                        <li class="page-item {{ pagination.page <= 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('app_product_index', baseQuery|merge({ sort: filters.sort, dir: filters.dir, page: prevPage })) }}">Anterior</a>
                        </li>
                        {% for p in 1..pagination.pages %}
                            <li class="page-item {{ p == pagination.page ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('app_product_index', baseQuery|merge({ sort: filters.sort, dir: filters.dir, page: p })) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                        {% set nextPage = pagination.page + 1 %}
                        <li class="page-item {{ pagination.page >= pagination.pages ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('app_product_index', baseQuery|merge({ sort: filters.sort, dir: filters.dir, page: nextPage })) }}">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        </div>
    </div>
{% endblock %}
