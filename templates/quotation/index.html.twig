{% extends 'base.html.twig' %}

{% block title %}Presupuestos | ItaStock{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Presupuestos</h1>
            <p class="text-muted mb-0">Listado de presupuestos emitidos por el comercio.</p>
        </div>
        <a href="{{ path('app_sale_new') }}" class="btn btn-primary">Nuevo desde POS</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form class="row g-2 mb-3" method="get">
                <div class="col-md-8">
                    <input type="search" class="form-control" name="q" value="{{ query }}" placeholder="Buscar por cliente, vendedor o número">
                </div>
                <div class="col-md-4 d-grid d-md-flex justify-content-md-end gap-2">
                    <button class="btn btn-outline-secondary" type="submit">Buscar</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Vendedor</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for quotation in quotations %}
                        <tr>
                            <td class="fw-semibold">{{ quotation.commercialNumber }}</td>
                            <td>{{ quotation.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ quotation.customer ? quotation.customer.name : 'Consumidor final' }}</td>
                            <td>{{ quotation.createdBy ? quotation.createdBy.fullName : 'N/D' }}</td>
                            <td class="text-end">${{ quotation.total }}</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_quotation_show', {id: quotation.id}) }}">Ver detalle</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No hay presupuestos para mostrar.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if pages > 1 %}
                <nav>
                    <ul class="pagination mb-0 justify-content-end">
                        {% for p in 1..pages %}
                            <li class="page-item {{ p == page ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('app_quotation_index', {page: p, q: query}) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                </nav>
            {% endif %}
        </div>
    </div>
{% endblock %}
