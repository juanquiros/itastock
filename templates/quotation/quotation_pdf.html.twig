<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #222; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
        th, td { border: 1px solid #ddd; padding: 6px; }
        th { background: #f5f5f5; text-align: left; }
        .doc-title { text-align: center; border: 1px solid #222; padding: 8px; margin-bottom: 10px; }
        .doc-title .type { font-size: 20px; font-weight: bold; }
        .doc-title .number { font-size: 14px; margin-top: 4px; }
        .head-two td { width: 50%; vertical-align: top; border: 1px solid #222; padding: 8px; }
        .totals { margin-top: 8px; text-align: right; }
        .legend { margin-top: 16px; font-size: 11px; color: #555; text-align: center; }
        .text-center { text-align: center; }
    </style>
</head>
<body>
{% set headerLines = business.quotationHeaderLines ? business.quotationHeaderLines|replace({'\r': ''})|split('\n') : [] %}

<div class="doc-title">
    <div class="type">PRESUPUESTO</div>
    <div class="number">N° {{ quotation.commercialNumber }}</div>
</div>

<table class="head-two">
    <tr>
        <td>
            <div><strong>Comercio:</strong> {{ business.name }}</div>
            <div><strong>Fecha:</strong> {{ quotation.createdAt|date('d/m/Y H:i') }}</div>
            <div><strong>Vendedor:</strong> {{ quotation.createdBy ? quotation.createdBy.fullName : 'N/D' }}</div>
            <div><strong>Generado:</strong> {{ generatedAt|date('d/m/Y H:i') }}</div>
            <div><strong>Cliente:</strong> {{ quotation.customer ? quotation.customer.name : 'Consumidor final' }}</div>
            <div><strong>Lista aplicada:</strong> {{ quotation.priceListNameUsed ?: 'Lista base/default' }}</div>
        </td>
        <td class="text-center">
            {% if business.quotationHeaderImagePath %}
                <img src="{{ business.quotationHeaderImagePath }}" alt="Header" style="max-height: 120px; max-width: 100%; margin:0 auto; display:block;">
            {% endif %}
            {% for line in headerLines %}
                {% if line|trim %}
                    <div>{{ line }}</div>
                {% endif %}
            {% endfor %}
        </td>
    </tr>
</table>

<table>
    <thead>
    <tr>
        <th>Producto</th>
        <th style="text-align:right;">Cant.</th>
        <th style="text-align:right;">Precio</th>
        <th style="text-align:right;">Total</th>
    </tr>
    </thead>
    <tbody>
    {% for item in quotation.items %}
        <tr>
            <td>{{ item.description }}</td>
            <td style="text-align:right;">{{ item.qty|number_format(3, '.', ',') }}</td>
            <td style="text-align:right;">${{ item.unitPrice }}</td>
            <td style="text-align:right;">${{ item.lineTotal }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="totals">
    <div><strong>Subtotal:</strong> ${{ quotation.subtotal }}</div>
    <div><strong>Total:</strong> ${{ quotation.total }}</div>
</div>

{% if quotation.cashierComment %}
    <p><strong>Comentario del cajero:</strong> {{ quotation.cashierComment }}</p>
{% endif %}

{% set footerLines = business.quotationFooterLines ? business.quotationFooterLines|replace({'\r': ''})|split('\n') : [] %}
{% if footerLines %}
    <div class="text-center">
        {% for line in footerLines %}
            {% if line|trim %}<div>{{ line }}</div>{% endif %}
        {% endfor %}
    </div>
{% endif %}

{% if business.quotationFooterImagePath %}
    <div class="text-center" style="margin-top: 8px;">
        <img src="{{ business.quotationFooterImagePath }}" alt="Footer" style="max-height: 160px; max-width: 100%; margin:0 auto; display:block;">
    </div>
{% endif %}

<div class="legend">
    <strong>PRESUPUESTO — No válido como comprobante fiscal</strong>
</div>
</body>
</html>
