{% extends 'base.html.twig' %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4 mb-0">{{ rule.id ? 'Editar' : 'Nueva' }} regla fiscal</h1><a href="{{ path('app_fiscal_rule_index') }}" class="btn btn-outline-secondary btn-sm">Volver</a></div>
<form method="post" class="row g-3">
<div class="col-md-6"><label class="form-label">Nombre</label><input name="name" class="form-control" value="{{ rule.name }}" required></div>
<div class="col-md-2"><label class="form-label">Prioridad</label><input name="priority" type="number" class="form-control" value="{{ rule.priority }}"></div>
<div class="col-md-2 form-check mt-4"><input class="form-check-input" type="checkbox" name="active" value="1" {{ rule.active ? 'checked' : '' }}><label class="form-check-label">Activa</label></div>
<div class="col-md-4"><label class="form-label">Tipo componente</label><select name="componentType" class="form-select">{% for k,v in componentTypeLabels %}<option value="{{ k }}" {{ rule.componentType==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Aplica a</label><select name="appliesTo" class="form-select">{% for k,v in appliesToLabels %}<option value="{{ k }}" {{ rule.appliesTo==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Base de cálculo</label><select name="taxableBaseMode" class="form-select">{% for k,v in taxableBaseModeLabels %}<option value="{{ k }}" {{ rule.taxableBaseMode==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Producto</label><select name="productId" class="form-select"><option value="">-</option>{% for p in products %}<option value="{{ p.id }}" {{ rule.product and rule.product.id==p.id?'selected':'' }}>{{ p.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Categoría</label><select name="categoryId" class="form-select"><option value="">-</option>{% for c in categories %}<option value="{{ c.id }}" {{ rule.category and rule.category.id==c.id?'selected':'' }}>{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Cliente</label><select name="customerId" class="form-select"><option value="">-</option>{% for c in customers %}<option value="{{ c.id }}" {{ rule.customer and rule.customer.id==c.id?'selected':'' }}>{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Condición IVA cliente</label><select name="customerIvaConditionId" class="form-select"><option value="">-</option>{% for id,label in ivaConditionOptions %}<option value="{{ id }}" {{ rule.customerIvaConditionId==id?'selected':'' }}>{{ label }}</option>{% endfor %}</select></div>
<div class="col-md-2"><label class="form-label">Alícuota %</label><input name="rate" class="form-control" value="{{ rule.rate }}"></div><div class="col-md-2"><label class="form-label">Monto fijo</label><input name="fixedAmount" class="form-control" value="{{ rule.fixedAmount }}"></div>
<div class="col-md-2"><label class="form-label">Mínimo</label><input name="minAmount" class="form-control" value="{{ rule.minAmount }}"></div><div class="col-md-2"><label class="form-label">Máximo</label><input name="maxAmount" class="form-control" value="{{ rule.maxAmount }}"></div>
<div class="col-md-3"><label class="form-label">Jurisdicción</label><input name="jurisdiction" class="form-control" value="{{ rule.jurisdiction }}"></div>
<div class="col-md-3"><label class="form-label">Tributo ARCA</label><input name="arcaTributeId" class="form-control" value="{{ rule.arcaTributeId }}"></div>
<div class="col-md-3"><label class="form-label">Vigencia desde</label><input type="date" name="startsAt" class="form-control" value="{{ rule.startsAt ? rule.startsAt|date('Y-m-d') : '' }}"></div>
<div class="col-md-3"><label class="form-label">Vigencia hasta</label><input type="date" name="endsAt" class="form-control" value="{{ rule.endsAt ? rule.endsAt|date('Y-m-d') : '' }}"></div>
<div class="col-12"><label class="form-label">Descripción</label><input name="descriptionTemplate" class="form-control" value="{{ rule.descriptionTemplate }}"></div>
<div class="col-12 d-flex gap-3 flex-wrap">
{% for fld,label in {'reportToArca':'Informa ARCA','affectsTotal':'Afecta total','includedInPrice':'Incluido en precio','stopProcessing':'Detener procesamiento'} %}<div class="form-check"><input class="form-check-input" type="checkbox" name="{{ fld }}" value="1" {{ attribute(rule,fld) ? 'checked':'' }}><label class="form-check-label">{{ label }}</label></div>{% endfor %}
</div>
<div class="col-12"><button class="btn btn-primary">Guardar regla</button></div>
</form>
{% endblock %}
