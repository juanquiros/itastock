{% extends 'base.html.twig' %}
{% block body %}
<h1 class="h4">{{ rule.id ? 'Editar' : 'Nueva' }} regla fiscal</h1>
<form method="post" class="row g-3">
<input type="hidden" name="_token" value="{{ csrf_token(rule.id ? 'fiscal_rule_edit_' ~ rule.id : 'fiscal_rule_new') }}">
<div class="col-md-6"><label class="form-label">Nombre</label><input name="name" class="form-control" value="{{ rule.name }}"></div>
<div class="col-md-3"><label class="form-label">Aplica a</label><select name="appliesTo" class="form-select">{% for k,v in appliesToLabels %}<option value="{{ k }}" {{ rule.appliesTo==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-3"><label class="form-label">Modo</label><select name="applicationMode" class="form-select">{% for k,v in applicationModes %}<option value="{{ k }}" {{ rule.applicationMode==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Producto</label><select name="productId" class="form-select"><option value="">-</option>{% for p in products %}<option value="{{ p.id }}" {{ rule.product and rule.product.id == p.id ? 'selected' : '' }}>{{ p.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Categoría</label><select name="categoryId" class="form-select"><option value="">-</option>{% for c in categories %}<option value="{{ c.id }}" {{ rule.category and rule.category.id == c.id ? 'selected' : '' }}>{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Cliente</label><select name="customerId" class="form-select"><option value="">-</option>{% for c in customers %}<option value="{{ c.id }}" {{ rule.customer and rule.customer.id == c.id ? 'selected' : '' }}>{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Condición IVA</label><select name="customerIvaConditionId" class="form-select"><option value="">-</option>{% for id,label in ivaConditionOptions %}<option value="{{ id }}" {{ rule.customerIvaConditionId == id ? 'selected' : '' }}>{{ label }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Descripción</label><input name="descriptionTemplate" class="form-control" value="{{ rule.descriptionTemplate }}"><div class="form-text">Texto que se usará como descripción del tributo generado.</div></div>
<div class="col-md-2"><label class="form-label">Min</label><input name="minAmount" class="form-control" value="{{ rule.minAmount }}"><div class="form-text">Aplica solo si la base es igual o mayor.</div></div>
<div class="col-md-2"><label class="form-label">Max</label><input name="maxAmount" class="form-control" value="{{ rule.maxAmount }}"><div class="form-text">Aplica solo si la base es igual o menor.</div></div>
<div class="col-md-3"><label class="form-label">Desde</label><input type="date" name="startsAt" class="form-control" value="{{ rule.startsAt ? rule.startsAt|date('Y-m-d') : '' }}"></div>
<div class="col-md-3"><label class="form-label">Hasta</label><input type="date" name="endsAt" class="form-control" value="{{ rule.endsAt ? rule.endsAt|date('Y-m-d') : '' }}"></div>
<div class="col-md-2"><label class="form-label">Alícuota</label><input name="rate" class="form-control" value="{{ rule.rate }}"></div>
<div class="col-md-2"><label class="form-label">Monto fijo</label><input name="fixedAmount" class="form-control" value="{{ rule.fixedAmount }}"></div>
<div class="col-12"><button class="btn btn-primary">Guardar</button></div>
</form>
{% endblock %}
