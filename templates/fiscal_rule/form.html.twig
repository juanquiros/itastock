{% extends 'base.html.twig' %}{% block body %}<h1>{{ rule.id ? 'Editar' : 'Nueva' }} regla fiscal</h1><form method="post" class="row g-2"><div class="col-12"><input name="name" class="form-control" placeholder="Nombre" value="{{ rule.name }}"></div><div class="col-md-2"><input name="priority" class="form-control" value="{{ rule.priority }}"></div><div class="col-md-3"><input name="componentType" class="form-control" value="{{ rule.componentType }}"></div><div class="col-md-3"><input name="appliesTo" class="form-control" value="{{ rule.appliesTo }}"></div><div class="col-md-3"><input name="taxableBaseMode" class="form-control" value="{{ rule.taxableBaseMode }}"></div><div class="col-md-3"><input name="rate" class="form-control" placeholder="Alícuota" value="{{ rule.rate }}"></div><div class="col-md-3"><input name="fixedAmount" class="form-control" placeholder="Monto fijo" value="{{ rule.fixedAmount }}"></div><div class="col-md-3"><input name="minAmount" class="form-control" placeholder="Monto mínimo" value="{{ rule.minAmount }}"></div><div class="col-md-3"><input name="maxAmount" class="form-control" placeholder="Monto máximo" value="{{ rule.maxAmount }}"></div><div class="col-12"><button class="btn btn-primary">Guardar</button></div></form>{% endblock %}
