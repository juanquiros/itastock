{% extends 'base.html.twig' %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4 mb-0">{{ rule.id ? 'Editar' : 'Nueva' }} regla fiscal</h1><a href="{{ path('app_fiscal_rule_index') }}" class="btn btn-outline-secondary btn-sm">Volver</a></div>
<form method="post" class="row g-3">
<input type="hidden" name="_token" value="{{ csrf_token(rule.id ? 'fiscal_rule_edit_' ~ rule.id : 'fiscal_rule_new') }}">
<div class="col-md-6"><label class="form-label">Nombre</label><input name="name" class="form-control" value="{{ rule.name }}" required></div>
<div class="col-md-2"><label class="form-label">Prioridad</label><input name="priority" type="number" class="form-control" value="{{ rule.priority }}"></div>
<div class="col-md-2 form-check mt-4"><input class="form-check-input" type="checkbox" name="active" value="1" {{ rule.active ? 'checked' : '' }}><label class="form-check-label">Activa</label></div>
<div class="col-md-4"><label class="form-label">Tipo componente</label><select name="componentType" class="form-select">{% for k,v in componentTypeLabels %}<option value="{{ k }}" {{ rule.componentType==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Aplica a</label><select name="appliesTo" class="form-select">{% for k,v in appliesToLabels %}<option value="{{ k }}" {{ rule.appliesTo==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Base de cálculo</label><select name="taxableBaseMode" class="form-select">{% for k,v in taxableBaseModeLabels %}<option value="{{ k }}" {{ rule.taxableBaseMode==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Modo de aplicación</label><select name="applicationMode" class="form-select">{% for k,v in applicationModes %}<option value="{{ k }}" {{ rule.applicationMode==k?'selected':'' }}>{{ v }}</option>{% endfor %}</select><div class="form-text">Usar Solo sugerir para probar una regla sin afectar ventas.</div></div>
<div class="col-md-4"><label class="form-label">Producto</label><select name="productId" class="form-select"><option value="">-</option>{% for p in products %}<option value="{{ p.id }}">{{ p.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Categoría</label><select name="categoryId" class="form-select"><option value="">-</option>{% for c in categories %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Cliente</label><select name="customerId" class="form-select"><option value="">-</option>{% for c in customers %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}</select></div>
<div class="col-md-4"><label class="form-label">Condición IVA cliente</label><select name="customerIvaConditionId" class="form-select"><option value="">-</option>{% for id,label in ivaConditionOptions %}<option value="{{ id }}" {{ rule.customerIvaConditionId==id?'selected':'' }}>{{ label }}</option>{% endfor %}</select></div>
<div class="col-md-2"><label class="form-label">Alícuota %</label><input name="rate" class="form-control" value="{{ rule.rate }}"></div><div class="col-md-2"><label class="form-label">Monto fijo</label><input name="fixedAmount" class="form-control" value="{{ rule.fixedAmount }}"></div>
<div class="col-md-3"><label class="form-label">Jurisdicción</label><input name="jurisdiction" class="form-control" value="{{ rule.jurisdiction }}"></div><div class="col-md-3"><label class="form-label">Tributo ARCA</label><input name="arcaTributeId" class="form-control" value="{{ rule.arcaTributeId }}"><div class="form-text">Debe coincidir con el código de tributo válido para ARCA.</div></div>
<div class="col-12"><div class="alert alert-info py-2">ItaStock no valida padrones ni alícuotas externas en esta etapa. Confirmar con el contador.</div></div>
<div class="col-12 d-flex gap-3 flex-wrap"><div class="form-check"><input class="form-check-input" type="checkbox" name="reportToArca" value="1" {{ rule.reportToArca ? 'checked':'' }}><label class="form-check-label">Informa ARCA</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="affectsTotal" value="1" {{ rule.affectsTotal ? 'checked':'' }}><label class="form-check-label">Afecta total</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="includedInPrice" value="1" {{ rule.includedInPrice ? 'checked':'' }}><label class="form-check-label">Incluido en precio</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="stopProcessing" value="1" {{ rule.stopProcessing ? 'checked':'' }}><label class="form-check-label">Detener procesamiento</label></div></div>
<div class="col-12"><button class="btn btn-primary">Guardar regla</button></div>
</form>
{% endblock %}
