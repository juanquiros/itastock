{% extends 'base.html.twig' %}{% block body %}<h1 class='h4'>Auditoría reglas fiscales</h1><table class='table table-sm'><tr><th>Fecha</th><th>Usuario</th><th>Acción</th><th>Regla</th></tr>{% for l in logs %}<tr><td>{{ l.createdAt|date('d/m/Y H:i') }}</td><td>{{ l.user ? l.user.fullName : '-' }}</td><td>{{ l.action }}</td><td>{{ l.ruleName }}</td></tr>{% else %}<tr><td colspan='4'>Sin logs.</td></tr>{% endfor %}</table>{% endblock %}
