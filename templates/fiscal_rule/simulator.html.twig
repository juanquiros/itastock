{% extends 'base.html.twig' %}{% block body %}<h1 class='h4'>Simulador de reglas fiscales</h1><form method='post' class='row g-2'><div class='col-md-4'><select name='customerId' class='form-select'><option value=''>Cliente</option>{% for c in customers %}<option value='{{ c.id }}'>{{ c.name }}</option>{% endfor %}</select></div><div class='col-md-4'><select name='product1' class='form-select'><option value=''>Producto 1</option>{% for p in products %}<option value='{{ p.id }}'>{{ p.name }}</option>{% endfor %}</select></div><div class='col-md-2'><input name='qty1' class='form-control' value='1'></div><div class='col-12'><button class='btn btn-primary'>Simular</button></div></form>{% if result %}<div class='mt-3'><div>Total fiscal estimado: {{ result.fiscalComponentsTotal }}</div><h6>Aplicados</h6><ul>{% for c in result.automaticComponents %}<li>{{ c.description }}: {{ c.amount }}</li>{% else %}<li>-</li>{% endfor %}</ul><h6>Sugerencias</h6><ul>{% for c in result.suggestedComponents %}<li>{{ c.description }}: {{ c.amount }}</li>{% else %}<li>-</li>{% endfor %}</ul></div>{% endif %}{% endblock %}
