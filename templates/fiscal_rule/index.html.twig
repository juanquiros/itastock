{% extends 'base.html.twig' %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4 mb-0">Reglas fiscales</h1><div><a class="btn btn-primary btn-sm" href="{{ path('app_fiscal_rule_new') }}">Nueva regla fiscal</a> <a class="btn btn-outline-primary btn-sm" href="{{ path('app_fiscal_rule_simulator') }}">Simulador</a> <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_fiscal_rule_audit') }}">Auditoría</a></div></div>
<table class="table table-sm align-middle"><thead><tr><th>Nombre</th><th>Estado</th><th>Modo</th><th>Tipo componente</th><th>Aplica a</th><th>Base</th><th>Alícuota</th><th>Monto fijo</th><th>Afecta total</th><th>ARCA</th><th>Vigencia</th><th>Acciones</th></tr></thead><tbody>
{% for r in rules %}
{% set ap = appliesToLabels[r.appliesTo]|default(r.appliesTo) %}
{% set incompleta = false %}
{% if r.appliesTo == 'PRODUCT' %}{% if r.product %}{% set ap = ap ~ ': ' ~ r.product.name %}{% else %}{% set ap = ap ~ ': Incompleta' %}{% set incompleta = true %}{% endif %}{% elseif r.appliesTo == 'CATEGORY' %}{% if r.category %}{% set ap = ap ~ ': ' ~ r.category.name %}{% else %}{% set ap = ap ~ ': Incompleta' %}{% set incompleta = true %}{% endif %}{% elseif r.appliesTo == 'CUSTOMER' %}{% if r.customer %}{% set ap = ap ~ ': ' ~ r.customer.name %}{% else %}{% set ap = ap ~ ': Incompleta' %}{% set incompleta = true %}{% endif %}{% elseif r.appliesTo == 'CUSTOMER_IVA_CONDITION' %}{% if r.customerIvaConditionId %}{% set ap = ap ~ ': ' ~ ivaConditionOptions[r.customerIvaConditionId]|default(r.customerIvaConditionId) %}{% else %}{% set ap = ap ~ ': Incompleta' %}{% set incompleta = true %}{% endif %}{% endif %}
{% set vigencia = 'Vigente' %}{% if r.endsAt and r.endsAt < today %}{% set vigencia = 'Vencida' %}{% elseif r.startsAt and r.startsAt > today %}{% set vigencia = 'Programada' %}{% endif %}
<tr><td>{{ r.name }}</td><td><span class="badge {{ r.active ? 'text-bg-success':'text-bg-secondary' }}">{{ r.active ? 'Activa':'Inactiva' }}</span></td><td><span class="badge {{ r.applicationMode == 'SUGGEST' ? 'text-bg-info':'text-bg-primary' }}">{{ r.applicationMode }}</span></td><td>{{ componentTypeLabels[r.componentType]|default(r.componentType) }}</td><td>{{ ap }} {% if incompleta %}<span class="badge text-bg-warning">Incompleta</span>{% endif %}</td><td>{{ r.taxableBaseMode }}</td><td>{{ r.rate ?: '-' }}</td><td>{{ r.fixedAmount ?: '-' }}</td><td>{{ r.affectsTotal ? 'Sí':'No' }}</td><td>{% if r.reportToArca and not r.arcaTributeId %}<span class="badge text-bg-warning">Sin código ARCA</span>{% elseif r.reportToArca %}{{ r.arcaTributeId }}{% else %}No informa{% endif %}</td><td><span class="badge {{ vigencia == 'Vigente' ? 'text-bg-success' : (vigencia == 'Vencida' ? 'text-bg-danger' : 'text-bg-secondary') }}">{{ vigencia }}</span></td><td><a class="btn btn-outline-secondary btn-sm" href="{{ path('app_fiscal_rule_edit',{id:r.id}) }}">Editar</a> <form class="d-inline" method="post" action="{{ path('app_fiscal_rule_toggle',{id:r.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('fiscal_rule_toggle_' ~ r.id) }}"><button class="btn btn-outline-warning btn-sm">{{ r.active ? 'Desactivar':'Activar' }}</button></form> <form class="d-inline" method="post" action="{{ path('app_fiscal_rule_delete',{id:r.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('fiscal_rule_delete_' ~ r.id) }}"><button class="btn btn-outline-danger btn-sm">Eliminar</button></form> <a class="btn btn-outline-info btn-sm" href="{{ path('app_fiscal_rule_audit') }}">Ver auditoría</a></td></tr>
{% else %}<tr><td colspan="12">No hay reglas fiscales configuradas.</td></tr>{% endfor %}
</tbody></table>
{% endblock %}
