{% extends 'base.html.twig' %}
{% block body %}
<div class="d-flex justify-content-between mb-3"><h1 class="h4 mb-0">Reglas fiscales</h1><a href="{{ path('app_fiscal_rule_new') }}" class="btn btn-primary btn-sm">Nueva regla fiscal</a></div>
{% if rules is empty %}<div class="alert alert-secondary">No hay reglas fiscales configuradas.</div>{% else %}
<table class="table table-sm align-middle"><thead><tr><th>Nombre</th><th>Activo</th><th>Tipo</th><th>Aplica a</th><th>Prioridad</th><th>Alícuota</th><th>Monto fijo</th><th>Vigencia</th><th></th></tr></thead><tbody>
{% for r in rules %}<tr><td>{{ r.name }}</td><td>{{ r.active?'Sí':'No' }}</td><td>{{ componentTypeLabels[r.componentType]|default(r.componentType) }}</td><td>{{ appliesToLabels[r.appliesTo]|default(r.appliesTo) }}</td><td>{{ r.priority }}</td><td>{{ r.rate ?? '-' }}</td><td>{{ r.fixedAmount ?? '-' }}</td><td>{{ r.startsAt ? r.startsAt|date('d/m/Y') : '-' }} - {{ r.endsAt ? r.endsAt|date('d/m/Y') : '-' }}</td><td><a class="btn btn-outline-secondary btn-sm" href="{{ path('app_fiscal_rule_edit',{id:r.id}) }}">Editar</a> <form method="post" action="{{ path('app_fiscal_rule_toggle',{id:r.id}) }}" class="d-inline"><button class="btn btn-outline-warning btn-sm">{{ r.active?'Desactivar':'Activar' }}</button></form> <form method="post" action="{{ path('app_fiscal_rule_delete',{id:r.id}) }}" class="d-inline" onsubmit="return confirm('¿Eliminar regla?');"><button class="btn btn-outline-danger btn-sm">Eliminar</button></form></td></tr>{% endfor %}
</tbody></table>{% endif %}
{% endblock %}
