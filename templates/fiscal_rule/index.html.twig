{% extends 'base.html.twig' %}{% block body %}<h1>Reglas fiscales</h1><a href="{{ path('app_fiscal_rule_new') }}" class="btn btn-primary btn-sm">Nueva</a><table class="table"><tr><th>Nombre</th><th>Activo</th><th>Prioridad</th><th></th></tr>{% for r in rules %}<tr><td>{{ r.name }}</td><td>{{ r.active ? 'Sí':'No' }}</td><td>{{ r.priority }}</td><td><a href="{{ path('app_fiscal_rule_edit',{id:r.id}) }}">Editar</a></td></tr>{% endfor %}</table>{% endblock %}
