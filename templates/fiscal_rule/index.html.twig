{% extends 'base.html.twig' %}
{% block body %}
<div class="d-flex justify-content-between mb-3"><h1 class="h4 mb-0">Reglas fiscales</h1><div><a href="{{ path('app_fiscal_rule_new') }}" class="btn btn-primary btn-sm">Nueva regla fiscal</a> <a href="{{ path('app_fiscal_rule_simulator') }}" class="btn btn-outline-primary btn-sm">Simulador</a> <a href="{{ path('app_fiscal_rule_audit') }}" class="btn btn-outline-secondary btn-sm">Ver auditoría</a></div></div>
<table class="table table-sm"><tr><th>Nombre</th><th>Estado</th><th>Modo</th><th>Tipo</th><th>Aplica a</th><th>Prioridad</th><th>ARCA</th><th>Vigencia</th><th></th></tr>{% for r in rules %}<tr><td>{{ r.name }}</td><td><span class="badge {{ r.active?'text-bg-success':'text-bg-secondary' }}">{{ r.active?'Activa':'Inactiva' }}</span></td><td><span class="badge {{ r.applicationMode=='SUGGEST'?'text-bg-info':'text-bg-primary' }}">{{ r.applicationMode }}</span></td><td>{{ componentTypeLabels[r.componentType]|default(r.componentType) }}</td><td>{{ appliesToLabels[r.appliesTo]|default(r.appliesTo) }}</td><td>{{ r.priority }}</td><td>{% if r.reportToArca %}{% if r.arcaTributeId %}<span class="badge text-bg-success">{{ r.arcaTributeId }}</span>{% else %}<span class="badge text-bg-warning">Sin código ARCA</span>{% endif %}{% else %}<span class="badge text-bg-secondary">No informa</span>{% endif %}</td><td>{% set vigente = (not r.startsAt or r.startsAt <= today) and (not r.endsAt or r.endsAt >= today) %}<span class="badge {{ vigente?'text-bg-success':'text-bg-secondary' }}">{{ vigente?'Vigente':'Fuera de vigencia' }}</span></td><td><a href="{{ path('app_fiscal_rule_edit',{id:r.id}) }}" class="btn btn-outline-secondary btn-sm">Editar</a><form method="post" action="{{ path('app_fiscal_rule_toggle',{id:r.id}) }}" class="d-inline"><input type="hidden" name="_token" value="{{ csrf_token('fiscal_rule_toggle_' ~ r.id) }}"><button class="btn btn-outline-warning btn-sm">{{ r.active?'Desactivar':'Activar' }}</button></form><form method="post" action="{{ path('app_fiscal_rule_delete',{id:r.id}) }}" class="d-inline"><input type="hidden" name="_token" value="{{ csrf_token('fiscal_rule_delete_' ~ r.id) }}"><button class="btn btn-outline-danger btn-sm">Eliminar</button></form></td></tr>{% else %}<tr><td colspan="9">No hay reglas fiscales configuradas.</td></tr>{% endfor %}</table>
{% endblock %}
