{% extends 'base.html.twig' %}

{% block title %}Configuración de stock | ItaStock{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Configuración de stock</h1>
            <p class="text-muted mb-0">Definí cómo se comporta la caja cuando falta carga de existencia.</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_row(form.allowNegativeStock) }}

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button class="btn btn-primary">Guardar</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
