{% extends 'base.html.twig' %}

{% block title %}Exportaciones de etiquetas · ItaStock{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <p class="text-uppercase text-muted mb-1 small fw-semibold">Exportaciones</p>
            <h1 class="h4 mb-0">Etiquetas en cola</h1>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_product_labels') }}">Nueva exportación</a>
    </div>

    <div class="card shadow-sm" data-exports-list>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>ID</th><th>Estado</th><th>Progreso</th><th>Creado</th><th></th></tr></thead>
                    <tbody>
                    {% for job in jobs %}
                        <tr data-job-row data-status-url="{{ path('app_exports_labels_status', {id: job.id}) }}" data-final="{{ job.status in ['READY', 'FAILED', 'EXPIRED'] ? '1' : '0' }}">
                            <td>#{{ job.id }}</td>
                            <td><span class="badge text-bg-secondary" data-job-status>{{ job.status }}</span></td>
                            <td>
                                <div class="small" data-job-progress-text>{{ job.progressText }}</div>
                                <div class="small text-muted" data-job-progress>{{ job.progressPercent }}% · {{ job.doneBatches }}/{{ job.totalBatches }}</div>
                            </td>
                            <td>{{ job.createdAt|date('d/m/Y H:i') }}</td>
                            <td><a class="btn btn-sm btn-outline-primary" href="{{ path('app_exports_labels_show', {id: job.id}) }}">Ver</a></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-muted">Todavía no hay exportaciones.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            let timeoutId = null;

            const isFinal = (status) => ['READY', 'FAILED', 'EXPIRED'].includes(status);

            const buildRequestUrl = (baseUrl) => {
                const separator = baseUrl.includes('?') ? '&' : '?';
                return `${baseUrl}${separator}_ts=${Date.now()}`;
            };

            const updateRow = (row, data) => {
                const statusEl = row.querySelector('[data-job-status]');
                const progressTextEl = row.querySelector('[data-job-progress-text]');
                const progressEl = row.querySelector('[data-job-progress]');
                if (statusEl) statusEl.textContent = data.status;
                if (progressTextEl) progressTextEl.textContent = data.progressText;
                if (progressEl) progressEl.textContent = `${data.progressPercent}% · ${data.doneBatches}/${data.totalBatches}`;
                row.dataset.final = isFinal(data.status) ? '1' : '0';
            };

            const scheduleNextTick = (callback) => {
                if (timeoutId !== null) {
                    clearTimeout(timeoutId);
                }
                timeoutId = setTimeout(callback, 3000);
            };

            const boot = () => {
                const container = document.querySelector('[data-exports-list]');
                if (!container) return;

                const rows = Array.from(container.querySelectorAll('[data-job-row]'));
                if (rows.length === 0) return;

                const tick = async () => {
                    const activeRows = rows.filter((row) => row.dataset.final !== '1');
                    if (activeRows.length === 0) return;

                    await Promise.all(activeRows.map(async (row) => {
                        const url = row.dataset.statusUrl;
                        if (!url) return;
                        try {
                            const response = await fetch(buildRequestUrl(url), {
                                cache: 'no-store',
                                headers: {'Accept': 'application/json'},
                            });
                            if (!response.ok) return;
                            updateRow(row, await response.json());
                        } catch (error) {
                            console.error('No se pudo refrescar el estado de exportación', error);
                        }
                    }));

                    if (rows.some((row) => row.dataset.final !== '1')) {
                        scheduleNextTick(tick);
                    }
                };

                scheduleNextTick(tick);
            };

            const stop = () => {
                if (timeoutId !== null) {
                    clearTimeout(timeoutId);
                    timeoutId = null;
                }
            };

            document.addEventListener('DOMContentLoaded', boot);
            document.addEventListener('turbo:load', boot);
            document.addEventListener('turbo:before-cache', stop);
        })();
    </script>
{% endblock %}
