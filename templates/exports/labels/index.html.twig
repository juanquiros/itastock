{% extends 'base.html.twig' %}

{% block title %}Exportes recientes de etiquetas · ItaStock{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <p class="text-uppercase text-muted mb-1 small fw-semibold">Etiquetas</p>
            <h1 class="h4 mb-0">Exportes recientes</h1>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_product_labels') }}">Volver a etiquetas</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                <tr>
                    <th>Fecha</th><th>Template</th><th class="text-end">Productos</th><th class="text-end">Lotes</th><th>Estado</th><th>Expira</th><th class="text-end">Acciones</th>
                </tr>
                </thead>
                <tbody>
                {% for export in exports %}
                    <tr>
                        <td>{{ export.createdAt|date('d/m/Y H:i') }}</td>
                        <td>{{ export.type }}</td>
                        <td class="text-end">{{ export.totalProducts }}</td>
                        <td class="text-end">{{ export.batchesCount }}</td>
                        <td><span class="badge bg-secondary">{{ export.status }}</span></td>
                        <td>{{ export.expiresAt|date('d/m/Y H:i') }}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_label_export_show', {id: export.id}) }}">Detalle</a>
                            {% if export.zipFilename %}
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_label_export_zip', {id: export.id}) }}">ZIP</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="text-center text-muted">Todavía no hay exportes.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
