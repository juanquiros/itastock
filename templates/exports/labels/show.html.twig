{% extends 'base.html.twig' %}

{% block title %}Detalle export etiquetas · ItaStock{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-0">Export #{{ export.id }}</h1>
            <p class="text-muted mb-0">Vence: {{ export.expiresAt|date('d/m/Y H:i') }} · Estado: {{ export.status }}</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_label_export_index') }}">Volver</a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex gap-2">
            {% if export.zipFilename %}
                <a class="btn btn-outline-primary" href="{{ path('app_label_export_zip', {id: export.id}) }}">Descargar ZIP</a>
            {% endif %}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light"><tr><th>Lote</th><th>Rango IDs</th><th class="text-end">Productos</th><th>Estado</th><th class="text-end">Acción</th></tr></thead>
                <tbody>
                {% for batch in export.batches %}
                    <tr>
                        <td>#{{ batch.batchIndex }}</td>
                        <td>{{ batch.fromProductId }} - {{ batch.toProductId }}</td>
                        <td class="text-end">{{ batch.productsCount }}</td>
                        <td>{{ batch.status }}</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-secondary" href="{{ path('app_label_export_batch', {id: export.id, batchId: batch.id}) }}">PDF</a></td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center text-muted">Sin lotes generados.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
