<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #222; }
        h1 { font-size: 18px; margin-bottom: 4px; }
        h2 { font-size: 14px; margin: 12px 0 6px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
        th, td { border: 1px solid #ddd; padding: 6px; }
        th { background: #f5f5f5; text-align: left; }
        .meta { margin-bottom: 12px; }
        .meta div { margin-bottom: 4px; }
        .totals { margin-top: 8px; text-align: right; }
        .legend { margin-top: 16px; font-size: 11px; color: #555; }
    </style>
</head>
<body>


    {% set fiscalEnabled = business.arcaConfig is defined and business.arcaConfig and business.arcaConfig.fiscalTransparencyEnabled %}
    {% set relatedInvoice = creditNote.relatedInvoice|default(null) %}
    {% set fiscalSnapshot = relatedInvoice ? relatedInvoice.fiscalComponentsSnapshot|default([]) : [] %}
    {% if fiscalSnapshot is not iterable %}{% set fiscalSnapshot = [] %}{% endif %}
    {% set fiscalTotal = relatedInvoice ? (relatedInvoice.fiscalComponentsTotal|default('0.00') + 0) : 0 %}
    {% set internalTaxesTotal = 0 %}
    {% for component in fiscalSnapshot %}
        {% if component.componentType|default('') == 'INTERNAL_TAX' %}
            {% set internalTaxesTotal = internalTaxesTotal + (component.amount|default('0.00') + 0) %}
        {% endif %}
    {% endfor %}
    {% set hasInternalTaxes = internalTaxesTotal > 0 %}
    {% set noteNet = creditNote.netAmount is defined ? (creditNote.netAmount|default('0.00') + 0) : 0 %}
    {% set noteVat = creditNote.vatAmount is defined ? (creditNote.vatAmount|default('0.00') + 0) : 0 %}
    {% set noteTotal = creditNote.totalAmount is defined ? (creditNote.totalAmount|default('0.00') + 0) : 0 %}
    {% set showFiscalDetail = fiscalEnabled and (noteNet > 0 or noteVat > 0 or noteTotal > 0 or fiscalTotal > 0 or hasInternalTaxes) %}
    <h1>Nota de Crédito {{ creditNote.cbteTipo == 'NC_B' ? 'B' : 'C' }}</h1>

    <div class="meta">
        <div><strong>Comercio:</strong> {{ business.name }}</div>
        <div><strong>CUIT:</strong> {{ business.arcaConfig ? business.arcaConfig.cuitEmisor : '-' }}</div>
        <div><strong>Punto de venta:</strong> {{ creditNote.arcaPosNumber }}</div>
        <div><strong>N° comprobante:</strong> {{ creditNote.cbteNumero ?: '-' }}</div>
        <div><strong>CAE:</strong> {{ creditNote.cae ?: '-' }}</div>
        <div><strong>Vto CAE:</strong> {{ creditNote.caeDueDate ? creditNote.caeDueDate|date('d/m/Y') : '-' }}</div>
        <div><strong>Fecha emisión:</strong> {{ creditNote.issuedAt ? creditNote.issuedAt|date('d/m/Y H:i') : sale.createdAt|date('d/m/Y H:i') }}</div>
        <div><strong>Factura asociada:</strong> {{ creditNote.relatedInvoice ? creditNote.relatedInvoice.cbteTipo : '-' }} {{ creditNote.relatedInvoice ? creditNote.relatedInvoice.arcaPosNumber : '' }} {{ creditNote.relatedInvoice ? creditNote.relatedInvoice.cbteNumero : '' }}</div>
        <div><strong>Cliente:</strong> {{ sale.customer ? sale.customer.name : 'Consumidor Final' }}</div>
        {% if sale.customer %}
            {% if sale.customer.documentType or sale.customer.documentNumber %}
                <div><strong>{{ sale.customer.documentType ?: 'Documento' }}:</strong> {{ sale.customer.documentNumber ?: '-' }}</div>
            {% endif %}
            {% if sale.customer.phone %}
                <div><strong>Teléfono:</strong> {{ sale.customer.phone }}</div>
            {% endif %}
            {% if sale.customer.address %}
                <div><strong>Dirección:</strong> {{ sale.customer.address }}</div>
            {% endif %}
        {% endif %}
        {% if creditNote.reason %}
            <div><strong>Motivo:</strong> {{ creditNote.reason }}</div>
        {% endif %}
    </div>

    <h2>Detalle de ítems</h2>
    <table>
        <thead>
            <tr>
                <th>Producto</th>
                <th style="text-align: right;">Cant.</th>
                <th style="text-align: right;">Precio</th>
                <th style="text-align: right;">IVA</th>
                <th style="text-align: right;">Total</th>
            </tr>
        </thead>
        <tbody>
        {% set items = creditNote.itemsSnapshot ?: [] %}
        {% if items %}
            {% for item in items %}
                <tr>
                    <td>{{ item.description }}</td>
                    <td style="text-align: right;">{{ item.qty }}</td>
                    <td style="text-align: right;">${{ item.unitPrice }}</td>
                    <td style="text-align: right;">{{ item.ivaRate }}%</td>
                    <td style="text-align: right;">${{ item.lineTotal }}</td>
                </tr>
            {% endfor %}
        {% else %}
            {% for item in sale.items %}
                <tr>
                    <td>{{ item.description }}</td>
                    <td style="text-align: right;">{{ item.qty|number_format(3, '.', ',') }}</td>
                    <td style="text-align: right;">${{ item.unitPrice }}</td>
                    <td style="text-align: right;">-</td>
                    <td style="text-align: right;">${{ item.lineTotal }}</td>
                </tr>
            {% endfor %}
        {% endif %}
        </tbody>
    </table>

    <div class="totals">
        <div><strong>Neto:</strong> ${{ creditNote.netAmount }}</div>
        <div><strong>IVA:</strong> ${{ creditNote.vatAmount }}</div>
        <div><strong>Total:</strong> ${{ creditNote.totalAmount }}</div>
    </div>

    {% if showFiscalDetail %}
        <div style="border-top:1px solid #ddd; margin-top:8px; padding-top:6px; font-size:11px; text-align:right;">
            <div style="text-align:left; font-weight:bold; margin-bottom:4px;">Detalle fiscal</div>
            {% if noteNet > 0 %}<div><strong>Neto:</strong> ${{ noteNet|number_format(2, '.', '') }}</div>{% endif %}
            {% if noteVat > 0 %}<div><strong>IVA:</strong> ${{ noteVat|number_format(2, '.', '') }}</div>{% endif %}
            {% if fiscalTotal > 0 %}<div><strong>Tributos/percepciones:</strong> ${{ fiscalTotal|number_format(2, '.', '') }}</div>{% endif %}
            {% if hasInternalTaxes %}<div><strong>Otros impuestos nacionales indirectos:</strong> ${{ internalTaxesTotal|number_format(2, '.', '') }}</div>{% endif %}
            {% if relatedInvoice and (fiscalTotal > 0 or hasInternalTaxes) %}<div style="text-align:left; color:#555;">Detalle fiscal según comprobante asociado.</div>{% endif %}
            {% if noteTotal > 0 %}<div><strong>Total:</strong> ${{ noteTotal|number_format(2, '.', '') }}</div>{% endif %}
        </div>
    {% endif %}

    <div style="margin-top:16px;">
        <div><strong>QR ARCA</strong></div>
        {% if qrDataUri is defined and qrDataUri %}
            <img src="{{ qrDataUri }}" alt="QR ARCA" style="width:140px;height:140px;">
            {% if qrUrl is defined and qrUrl %}
                <div style="font-size: 10px; color: #666; margin-top: 4px; word-break: break-all;">{{ qrUrl }}</div>
            {% endif %}
        {% else %}
            <div style="font-size: 11px; color: #777;">{{ creditNote.cae ? 'QR no disponible' : 'QR no disponible: sin CAE' }}</div>
        {% endif %}
    </div>

    <div class="legend">
        Comprobante emitido electrónicamente mediante ARCA. Generado en ItaStock el {{ generatedAt|date('d/m/Y H:i') }}.
    </div>
</body>
</html>
